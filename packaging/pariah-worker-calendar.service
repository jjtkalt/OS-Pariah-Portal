[Unit]
Description=OS Pariah Calendar Notifications (bot queue + reminders)
After=network.target mariadb.service pariah.service
Requires=pariah.service

[Service]
Type=oneshot
User=opensim
Group=opensim
WorkingDirectory=/opt/os_pariah
ExecStartPre=/opt/os_pariah/venv/bin/python /opt/os_pariah/scripts/check_mariadb.py
ExecStart=/opt/os_pariah/venv/bin/python /opt/os_pariah/scripts/worker.py calendar
