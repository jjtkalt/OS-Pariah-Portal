# Configuration file
#
# Local developers only: Modify and save this as .env
#
# Database Bootstrapping
PARIAH_DB_HOST=127.0.0.1
PARIAH_DB_USER=pariah
PARIAH_DB_PASS=Par1ahT3st
PARIAH_DB_NAME=os_pariah

# DATABASE ROBUST (OpenSim) - READ only
ROBUST_DB_HOST=127.0.0.1
ROBUST_DB_USER=robust_ro
ROBUST_DB_PASS=R0bustT3st
ROBUST_DB_NAME=robust

# Secret Keys
# Production: leave SECRET_KEY unset. It is auto-generated on first start into
# /etc/os_pariah/secrets (see scripts/ensure_secrets.py) so every install gets a
# strong, unique key. Do NOT ship a shared key in this file.
# Local dev only: uncomment and set your own value (not recommended), or let
# scripts/migrate.py generate a project-root .secrets file for you (recommended).
# SECRET_KEY=change-me-for-local-dev-only

# Bootstrap admin (optional - NOT recommended):
# Grant portal Super Admin to a specific OpenSim account UUID on every
# migrate/start, without needing a userLevel >= 250 account. Leave unset to
# rely on the default first-login auto-grant for userLevel >= 250.
# See scripts/migrate.py.
# ADMIN_UUID=
